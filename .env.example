# Verity local connected setup
# Copy to .env.local, then fill values from your Supabase project settings.

NEXT_PUBLIC_DATA_MODE=connected

# Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Project Settings -> API -> service_role key.
# Server-only. Never expose this in client code or browser tooling.
SUPABASE_SERVICE_ROLE_KEY=

# Use a strong admin password, at least 12 characters.
ADMIN_PASSWORD=

# Generate locally with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Local development URL. Set to your production domain in Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
